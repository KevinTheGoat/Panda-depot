---
import BaseLayout from '../layouts/BaseLayout.astro'
import HomeHero from '../components/HomeHero.jsx'
import HomeCategoryGrid from '../components/HomeCategoryGrid.jsx'
import catalogData from '../data/catalog.json'

const { company, categories, validPeriod } = catalogData
---

<BaseLayout>
  <HomeHero client:load company={company} categories={categories} />
  <HomeCategoryGrid client:visible categories={categories} validPeriod={validPeriod} />

  <!-- Info bar — static Astro HTML -->
  <section class="cloud-section bg-gradient-to-b from-panda-red/10 via-panda-red/5 to-panda-red/10">
    <div class="container-custom py-16 relative z-10">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 text-center">
        <div class="flex flex-col items-center gap-3">
          <div class="w-14 h-14 rounded-full bg-panda-red/10 border border-panda-red/20 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="#EE1C25" d="M20 8h-3V4H3c-1.1 0-2 .9-2 2v11h2c0 1.66 1.34 3 3 3s3-1.34 3-3h6c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-5zM6 18.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5s1.5.67 1.5 1.5s-.67 1.5-1.5 1.5M20 11l-3-3h-4v6H3V6h14v5m-2 5.5c.83 0 1.5.67 1.5 1.5s-.67 1.5-1.5 1.5s-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5"/></svg>
          </div>
          <h4 class="font-heading text-lg tracking-wide text-panda-red">FAST DELIVERY</h4>
          <p class="font-chinese text-panda-red/30 text-sm">快速配送</p>
          <p class="text-[#6B5D4F] text-sm">Daily delivery to restaurants</p>
        </div>
        <div class="flex flex-col items-center gap-3">
          <div class="w-14 h-14 rounded-full bg-panda-red/10 border border-panda-red/20 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="#EE1C25" d="M7 15h2c0 1.08 1.37 2 3 2s3-.92 3-2c0-1.1-1.04-1.5-3.24-2.03C9.64 12.44 7 11.78 7 9c0-1.79 1.47-3.31 3.5-3.82V3h3v2.18C15.53 5.69 17 7.21 17 9h-2c0-1.08-1.37-2-3-2s-3 .92-3 2c0 1.1 1.04 1.5 3.24 2.03C14.36 11.56 17 12.22 17 15c0 1.79-1.47 3.31-3.5 3.82V21h-3v-2.18C8.47 18.31 7 16.79 7 15"/></svg>
          </div>
          <h4 class="font-heading text-lg tracking-wide text-panda-red">WHOLESALE PRICES</h4>
          <p class="font-chinese text-panda-red/30 text-sm">批发价格</p>
          <p class="text-[#6B5D4F] text-sm">Bulk discounts on every order</p>
        </div>
        <div class="flex flex-col items-center gap-3">
          <div class="w-14 h-14 rounded-full bg-panda-red/10 border border-panda-red/20 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="#EE1C25" d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12c5.16-1.26 9-6.45 9-12V5zm-2 16l-4-4l1.41-1.41L10 14.17l6.59-6.59L18 9z"/></svg>
          </div>
          <h4 class="font-heading text-lg tracking-wide text-panda-red">QUALITY GUARANTEED</h4>
          <p class="font-chinese text-panda-red/30 text-sm">质量保证</p>
          <p class="text-[#6B5D4F] text-sm">All products on approval</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
